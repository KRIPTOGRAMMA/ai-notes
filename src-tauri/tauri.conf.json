{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ai-notes",
  "version": "0.5.0",
  "identifier": "com.ainotes.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ai-notes",
        "label": "main",
        "url": "index.html",
        "width": 800,
        "height": 600
      },
      {
        "title": "Быстрый ввод",
        "width": 420,
        "height": 300,
        "label": "quick-task",
        "url": "quick-task.html",
        "visible": false,
        "resizable": false,
        "alwaysOnTop": true,
        "decorations": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "open": false
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/llamafile",
      "binaries/llamafile-wrapper"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}